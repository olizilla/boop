{
  "name": "boop",
  "version": "0.1.3",
  "private": true,
  "license": "GPL-3.0",
  "type": "module",
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:release": "bash scripts/smoke-test-all.sh",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "setup": "bash scripts/setup.sh",
    "check-deps": "node scripts/check-deps.js",
    "version": "node scripts/sync-version.js && git add src-tauri/tauri.conf.json src-tauri/Cargo.toml src-tauri/boop-core/Cargo.toml src-tauri/Cargo.lock",
    "icon": "node scripts/generate-icon.js && tauri icon app_icon.svg && rm app_icon.svg"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@solidjs/testing-library": "^0.8.10",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "jsdom": "^29.0.2",
    "vite": "^8.0.8",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "solid-js": "^1.9.12"
  }
}
